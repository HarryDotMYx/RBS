# Database runtime settings (used by both app datasource and MariaDB container)
DB_HOST=db
DB_PORT=3306
DB_NAME=roombooking
DB_USER=roombooking
DB_PASSWORD=roombooking123
DB_ROOT_PASSWORD=change-me-root-password

# Installation behavior
AUTO_INSTALL=true
ADMIN_EMAIL=admin@example.com

# SMTP for password reset / notification emails (optional, but required to send mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_SSL=false

# Initial admin password is generated randomly at first auto-install and logged once.
