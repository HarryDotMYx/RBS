# Database runtime settings (used by both app datasource and MariaDB container)
DB_HOST=db
DB_PORT=3306
DB_NAME=roombooking
DB_USER=roombooking
DB_PASSWORD=roombooking123
DB_ROOT_PASSWORD=change-me-root-password

# Installation behavior
AUTO_INSTALL=true
ADMIN_EMAIL=admin@example.com

# Optional: enable `?reload=true&password=...` only when this is set
RBS_RELOAD_PASSWORD=

# Optional: isolate app/session namespace per instance (recommended when running dev+prod on same host)
RBS_INSTANCE_NAME=

# Optional legacy compatibility. Keep `false` to block URL token auth (`?token=...`) and use headers only.
API_ALLOW_QUERY_TOKEN=false

# SMTP for password reset / notification emails (optional, but required to send mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_SSL=false

# Initial admin password is generated randomly at first auto-install and logged once.
